<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.insidesuccesstv.cutsheet" ExtensionBundleVersion="1.0.0" ExtensionBundleName="Inside Success TV — Cut Sheet Generator">
  <ExtensionList>
    <Extension Id="com.insidesuccesstv.cutsheet.panel" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="PPRO" Version="[13.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="7.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.insidesuccesstv.cutsheet.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--allow-running-insecure-content</Parameter>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Inside Success TV — Cut Sheet</Menu>
          <Geometry>
            <Size>
              <Height>900</Height>
              <Width>420</Width>
            </Size>
            <MinSize>
              <Height>600</Height>
              <Width>360</Width>
            </MinSize>
            <MaxSize>
              <Height>2000</Height>
              <Width>800</Width>
            </MaxSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./icons/icon_normal.png</Icon>
            <Icon Type="RollOver">./icons/icon_hover.png</Icon>
            <Icon Type="DarkNormal">./icons/icon_normal.png</Icon>
            <Icon Type="DarkRollOver">./icons/icon_hover.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
