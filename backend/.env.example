# ── API Keys (required) ──────────────────────────────────────────────────────

# Rev AI - Speech-to-text transcription
REV_AI_TOKEN=your_rev_ai_token_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Pexels API (optional - enables B-roll verification with real Pexels search results)
PEXELS_API_KEY=your_pexels_api_key_here


# ── Production settings (optional — defaults work for local dev) ─────────────

# Persistent storage directory.  On Render set to /data (persistent disk).
# DATA_DIR=/data

# Override path to the editor cut-sheet prompt (default: ../DOCUMENTARY_CUT_SHEET_PROMPT.txt from backend/)
# CUTSHEET_PROMPT_FILE=/absolute/path/to/prompt.txt

# CORS origins.  Comma-separated or "*" for dev.
# CORS_ORIGINS=https://your-frontend.vercel.app

# Concurrency limits (tune for your Render plan)
# MAX_CONCURRENT_FFMPEG=3
# MAX_CONCURRENT_REVAI=4
# MAX_CONCURRENT_AI=6

# Auto-delete uploaded/generated files older than N hours
# FILE_MAX_AGE_HOURS=24

# App version string returned by /api/health (bump on deploy)
# APP_VERSION=2.1.0

# Transcription prep: FFmpeg only if upload is LARGER than this many MB (default 200).
# At or below → file is copied as-is to Rev (saves time for e.g. 150 MB MP3s).
# COMPRESS_AUDIO_ABOVE_MB=200

# FFmpeg max processing time per file in seconds (default 1800 = 30 minutes)
# FFMPEG_TIMEOUT_SECONDS=1800
